/**
 * qing-service-llm 独立 CI/CD 流水线
 *
 * 完全代码化：无需在 Jenkins 中配置任何共享库
 * 共享库通过 evaluate(readTrusted()) 从代码库加载
 */

// ==================== 加载共享库 ====================

def common = evaluate(readTrusted('jenkins/lib/common.groovy'))
def maven = evaluate(readTrusted('jenkins/lib/maven.groovy'))
def docker = evaluate(readTrusted('jenkins/lib/docker.groovy'))
def k8s = evaluate(readTrusted('jenkins/lib/kubernetes.groovy'))

// ==================== 服务配置 ====================

def SERVICE_NAME = 'llm'
def MODULE_NAME = 'qing-service-llm'

// ==================== 主流水线 ====================

pipeline {
    agent {
        label 'local'
    }

    options {
        skipDefaultCheckout(false)
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
        retry(0)
    }

    parameters {
        choice(
            name: 'BUILD_TYPE',
            choices: ['debug', 'release'],
            description: '选择构建类型'
        )
    }

    environment {
        REGISTRY_URL = 'your-registry'
    }

    stages {
        stage('拉取项目代码') {
            steps {
                checkout scm
            }
        }

        stage('显示构建信息') {
            steps {
                script {
                    common.printBuildInfo([
                        serviceName: SERVICE_NAME,
                        moduleName: MODULE_NAME,
                        buildType: params.BUILD_TYPE,
                        buildNumber: env.BUILD_NUMBER
                    ])
                }
            }
        }

        stage('验证依赖完整性') {
            steps {
                script {
                    echo "验证项目依赖..."
                    maven.validate(MODULE_NAME, common.getMavenOpts())
                }
            }
        }

        stage('安装基础依赖包') {
            steps {
                script {
                    echo "安装基础依赖..."
                    maven.install(MODULE_NAME, common.getMavenOpts())
                }
            }
        }

        stage('编译核心模块') {
            steps {
                script {
                    echo "编译核心模块..."
                    maven.compile(MODULE_NAME, common.getMavenOpts())
                }
            }
        }

        stage('单元测试') {
            steps {
                script {
                    echo "执行单元测试..."
                    maven.test(MODULE_NAME, common.getMavenOpts())
                }
            }
            post {
                always {
                    junit "${MODULE_NAME}/target/surefire-reports/*.xml"
                }
                failure {
                    echo "单元测试失败"
                    archiveArtifacts artifacts: "${MODULE_NAME}/target/surefire-reports/*.txt, ${MODULE_NAME}/target/surefire-reports/*.xml"
                }
            }
        }

        stage('代码质量检查') {
            steps {
                script {
                    echo "代码质量检查..."
                    maven.checkstyle(MODULE_NAME, common.getMavenOpts())
                }
            }
        }

        stage('编译打包') {
            steps {
                script {
                    if (params.BUILD_TYPE == 'release') {
                        echo "执行 Release 模式构建"
                    } else {
                        echo "执行 Debug 模式构建"
                    }
                    maven.package(MODULE_NAME, common.getMavenOpts(), params.BUILD_TYPE)
                }
            }
            post {
                success {
                    echo "编译打包成功"
                    common.archiveJar(MODULE_NAME)
                }
                failure {
                    echo "编译打包失败"
                }
            }
        }

        stage('构建 Docker 镜像') {
            when {
                expression { params.BUILD_TYPE == 'release' }
            }
            steps {
                script {
                    docker.build(SERVICE_NAME, MODULE_NAME, env.REGISTRY_URL, env.BUILD_NUMBER)
                }
            }
        }

        stage('部署到生产环境') {
            when {
                expression { params.BUILD_TYPE == 'release' }
            }
            steps {
                script {
                    docker.push(SERVICE_NAME, env.REGISTRY_URL, env.BUILD_NUMBER)
                    k8s.deploy(SERVICE_NAME, env.REGISTRY_URL, env.BUILD_NUMBER)
                }
            }
            post {
                success {
                    echo "部署成功"
                }
                failure {
                    echo "部署失败，尝试回滚"
                    script {
                        k8s.rollback(SERVICE_NAME)
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                currentBuild.description = "服务: ${SERVICE_NAME}, 类型: ${params.BUILD_TYPE}, 状态: ${currentBuild.result}"
            }
        }
        success {
            echo "=========================================="
            echo "  构建成功！"
            echo "=========================================="
        }
        failure {
            echo "=========================================="
            echo "  构建失败！"
            echo "=========================================="
        }
    }
}
