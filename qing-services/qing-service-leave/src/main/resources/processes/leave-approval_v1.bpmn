  <bpmn:process id="Signal_WithdrawLeave" name="请假审批流程" isExecutable="true" camunda:candidateStarterGroups="leaveApprovalProcess" camunda:historyTimeToLive="60">
    <bpmn:extensionElements>
      <camunda:executionListener class="cn.chenyunlong.qing.leave.event.TaskListener" event="start">
        <camunda:field name="TaskListener">
          <camunda:string>TaskListener</camunda:string>
        </camunda:field>
      </camunda:executionListener>
    </bpmn:extensionElements>
    <bpmn:startEvent id="StartEvent_LeaveRequest" name="发起流程">
      <bpmn:extensionElements>
        <camunda:formData />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_0dxgrt9</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_0dxgrt9" sourceRef="StartEvent_LeaveRequest" targetRef="Task_SupervisorApproval" />
    <bpmn:exclusiveGateway id="Gateway_SupervisorResult" name="主管审批结果">
      <bpmn:incoming>Flow_1rmcydn</bpmn:incoming>
      <bpmn:outgoing>Flow_12wmwy1</bpmn:outgoing>
      <bpmn:outgoing>Flow_0bj1tcy</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1rmcydn" sourceRef="Task_SupervisorApproval" targetRef="Gateway_SupervisorResult" />
    <bpmn:sequenceFlow id="Flow_12wmwy1" sourceRef="Gateway_SupervisorResult" targetRef="Task_HrApproval">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${supervisorApproved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:exclusiveGateway id="Gateway_1g92j2v" name="HR审批结果">
      <bpmn:incoming>Flow_0ff8052</bpmn:incoming>
      <bpmn:outgoing>Flow_0zz4p9b</bpmn:outgoing>
      <bpmn:outgoing>Flow_07sccq3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0ff8052" sourceRef="Task_HrApproval" targetRef="Gateway_1g92j2v" />
    <bpmn:sequenceFlow id="Flow_0zz4p9b" sourceRef="Gateway_1g92j2v" targetRef="Task_GmApproval">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${hrApproved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:exclusiveGateway id="Gateway_18c3d1c" name="总经理审批结果">
      <bpmn:incoming>Flow_1kxso3y</bpmn:incoming>
      <bpmn:outgoing>Flow_0srwdr5</bpmn:outgoing>
      <bpmn:outgoing>Flow_1m668x5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1kxso3y" sourceRef="Task_GmApproval" targetRef="Gateway_18c3d1c" />
    <bpmn:endEvent id="End_Approved" name="审批通过">
      <bpmn:incoming>Flow_0srwdr5</bpmn:incoming>
      <bpmn:incoming>Flow_0bj1tcy</bpmn:incoming>
      <bpmn:incoming>Flow_07sccq3</bpmn:incoming>
      <bpmn:incoming>Flow_1gpvqnb</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0srwdr5" sourceRef="Gateway_18c3d1c" targetRef="End_Approved">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${gmApproved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:userTask id="Task_HrApproval" name="HR审批" camunda:formRef="" camunda:formRefBinding="deployment" camunda:candidateGroups="hyper visor">
      <bpmn:incoming>Flow_12wmwy1</bpmn:incoming>
      <bpmn:outgoing>Flow_0ff8052</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_SupervisorApproval" name="主管审批" camunda:asyncBefore="true" camunda:asyncAfter="true" camunda:assignee="${directSupervisor}">
      <bpmn:incoming>Flow_0dxgrt9</bpmn:incoming>
      <bpmn:outgoing>Flow_1rmcydn</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_GmApproval" name="总经理审批">
      <bpmn:incoming>Flow_0zz4p9b</bpmn:incoming>
      <bpmn:outgoing>Flow_1kxso3y</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_0bj1tcy" sourceRef="Gateway_SupervisorResult" targetRef="End_Approved" />
    <bpmn:sequenceFlow id="Flow_07sccq3" sourceRef="Gateway_1g92j2v" targetRef="End_Approved" />
    <bpmn:task id="Activity_1n8917a" name="通知结果">
      <bpmn:incoming>Flow_1m668x5</bpmn:incoming>
